<Page loaded="onLoaded" class="page" actionBarHidden="true">
  <GridLayout rows="auto, auto, *, auto" class="shell">
    <GridLayout row="0" columns="*, auto" class="header">
      <StackLayout col="0">
        <Label text="Retail POS" class="eyebrow" />
        <Label text="Quick sale" class="screen-title" />
      </StackLayout>
      <StackLayout col="1" class="header-total">
        <Label text="{{ cartCountText }}" class="cart-count" />
        <Label text="{{ totalText }}" class="header-total-value" />
      </StackLayout>
    </GridLayout>

    <ScrollView row="1" orientation="horizontal" class="tabs">
      <StackLayout orientation="horizontal">
        <Button text="All" tap="onAllTap" />
        <Button text="Shoes" tap="onShoesTap" />
        <Button text="Boots" tap="onBootsTap" />
        <Button text="T-Shirts" tap="onTshirtsTap" />
        <Button text="Accessories" tap="onAccessoriesTap" />
      </StackLayout>
    </ScrollView>

    <ListView row="2" items="{{ products }}" class="product-list" separatorColor="transparent">
      <ListView.itemTemplate>
        <GridLayout columns="auto, *, auto" rows="auto, auto, auto" class="product-card">
          <GridLayout col="0" row="0" rowSpan="3" class="product-graphic">
            <Label text="{{ graphicText }}" class="product-graphic-text" />
          </GridLayout>
          <Label col="1" row="0" text="{{ name }}" class="product-name" />
          <Label col="1" row="1" text="{{ categoryText }}" class="product-meta" />
          <Label col="1" row="2" text="{{ priceText }}" class="product-price" />
          <Button col="2" row="0" rowSpan="3" text="+ Add" tap="onProductAddTap" class="add-button" />
        </GridLayout>
      </ListView.itemTemplate>
    </ListView>

    <StackLayout row="3" class="cart">
      <GridLayout columns="*, auto" class="cart-header">
        <Label col="0" text="Cart" class="cart-title" />
        <Label col="1" text="{{ subtotalText }}" class="subtotal" />
      </GridLayout>

      <Label text="No items added" class="empty-cart" visibility="{{ emptyCartVisible }}" />

      <Repeater items="{{ cartItems }}" visibility="{{ cartVisible }}">
        <Repeater.itemTemplate>
          <GridLayout columns="*, auto" rows="auto, auto" class="cart-item">
            <Label col="0" row="0" text="{{ name }}" class="cart-item-name" />
            <Label col="1" row="0" text="{{ priceText }}" class="cart-item-price" />
            <Label col="0" row="1" colSpan="2" text="{{ detail }}" class="cart-detail" />
          </GridLayout>
        </Repeater.itemTemplate>
      </Repeater>

      <GridLayout columns="*, auto" class="tax-row" visibility="{{ cartVisible }}">
        <Label col="0" text="{{ taxText }}" class="tax" />
        <Label col="1" text="{{ totalText }}" class="total" />
      </GridLayout>

      <Label text="{{ demoPaymentHint }}" class="payment-hint" visibility="{{ cartVisible }}" />
      <Button text="Pay with Demo Card" tap="onCheckoutTap" class="checkout" visibility="{{ cartVisible }}" />
    </StackLayout>
  </GridLayout>
</Page>
