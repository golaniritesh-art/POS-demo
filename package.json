{
  "name": "retail-pos",
  "main": "app/app.ts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android:build": "npx ns build android",
    "test:appium": "dotnet test tests/AppiumRegression/AppiumRegression.csproj",
    "test:appium:smoke": "dotnet test tests/AppiumRegression/AppiumRegression.csproj --filter TestCategory=Smoke",
    "test:browserstack": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/run-browserstack-appium.ps1",
    "test:browserstack:smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/run-browserstack-appium.ps1 -TestFilter TestCategory=Smoke",
    "test:browserstack:uploaded": "dotnet test tests/AppiumRegression/AppiumRegression.csproj -- TestRunParameters.Parameter(name=\"BROWSERSTACK_ENABLED\", value=\"true\")"
  },
  "dependencies": {
    "@nativescript/core": "~9.0.0",
    "@nativescript/theme": "^3.1.0",
    "mobx": "^6.15.0"
  },
  "devDependencies": {
    "@nativescript/android": "~9.0.0",
    "@nativescript/types": "~9.0.0",
    "@nativescript/webpack": "~5.0.25",
    "nativescript": "^9.0.6",
    "typescript": "~5.4.0"
  }
}
